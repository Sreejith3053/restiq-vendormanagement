// Storage Security Rules — Vendor Management (restiq-vendormanagement)
// Deploy via Firebase Console > Storage > Rules tab
//
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ── INVOICES ──────────────────────────────────────────────────────
    // PDF uploads only, max 10MB, authenticated users
    match /invoices/{type}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // ── EVERYTHING ELSE — deny by default ─────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
